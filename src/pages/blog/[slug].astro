---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { unsplashSrc } from '../../utils/image';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Posts recomendados: score por tags em comum + recência, sem restrição de categoria
const allPosts = await getCollection('blog');
const postTags = new Set(post.data.tags ?? []);

const related = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const sharedTags = (p.data.tags ?? []).filter((t) => postTags.has(t)).length;
    const sameCategory = p.data.category === post.data.category ? 1 : 0;
    const recency = p.data.pubDate.valueOf();
    return { post: p, score: sharedTags * 10 + sameCategory * 3 + recency / 1e12 };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((r) => r.post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  rating={post.data.rating}
  pros={post.data.pros}
  cons={post.data.cons}
  tags={post.data.tags}
  author={post.data.author}
>
  <Content />

  {related.length > 0 && (
    <section class="mt-20 pt-12 border-t border-border">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-6 bg-brand rounded-full"></div>
        <h2 class="text-xl font-bold">Artigos Recomendados</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {related.map((p) => (
          <a
            href={`/blog/${p.id}`}
            class="group block bg-card border border-border rounded-xl overflow-hidden hover:border-brand/40 transition-all duration-200 hover:-translate-y-0.5"
          >
            {p.data.image && (
              <div class="aspect-video overflow-hidden bg-elevated">
                <img
                  src={unsplashSrc(p.data.image, 400)}
                  srcset={`${unsplashSrc(p.data.image, 400)} 1x, ${unsplashSrc(p.data.image, 800)} 2x`}
                  alt={p.data.imageAlt ?? p.data.title}
                  width="400"
                  height="225"
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-4">
              <p class="text-xs text-brand font-semibold uppercase tracking-wider mb-2">{p.data.category}</p>
              <h3 class="font-semibold text-sm leading-snug text-foreground group-hover:text-brand transition-colors line-clamp-2">
                {p.data.title}
              </h3>
              <p class="text-xs text-muted mt-2 line-clamp-2">{p.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</PostLayout>
