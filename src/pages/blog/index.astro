---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { normalizeSearch } from '../../utils/slug';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['Todas', ...Array.from(new Set(allPosts.map((p) => p.data.category)))];
---

<BaseLayout
  title="Análises e Artigos"
  description="Navegue por todas as análises de guitarras, amplificadores, pedais e acessórios do Sonar Musical. Guias de compra e dicas para todos os níveis."
>
  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- Cabeçalho da página -->
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-black mb-4">Análises e Artigos</h1>
      <p class="text-muted max-w-xl mx-auto">
        {posts.length} artigos sobre guitarras, amplificadores, pedais e muito mais.
      </p>
    </div>

    <!-- Busca -->
    <div class="max-w-md mx-auto mb-8">
      <label for="post-search" class="sr-only">Buscar análises</label>
      <div class="relative">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-subtle" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input
          id="post-search"
          type="search"
          placeholder="Buscar por guitarra, pedal, amplificador..."
          class="w-full pl-10 pr-4 py-2.5 rounded-full border border-border bg-card text-sm text-foreground placeholder:text-subtle focus:outline-none focus:ring-2 focus:ring-brand/40"
        />
      </div>
    </div>

    <!-- Filtro por categoria -->
    <div class="flex flex-wrap gap-2 mb-10 justify-center" role="list" aria-label="Filtrar por categoria" id="category-filters">
      {categories.map((cat) => (
        <button
          type="button"
          data-category={cat}
          class={`category-btn px-4 py-2 rounded-full text-sm font-medium border transition-all ${
            cat === 'Todas'
              ? 'bg-brand border-brand text-white'
              : 'bg-transparent border-border text-muted hover:text-foreground hover:border-foreground/20'
          }`}
          aria-pressed={cat === 'Todas' ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Grid de posts -->
    <div id="posts-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <div
          data-category-item={post.data.category}
          data-search={normalizeSearch(`${post.data.title} ${post.data.description} ${(post.data.tags ?? []).join(' ')}`)}
        >
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            category={post.data.category}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            rating={post.data.rating}
            featured={post.data.featured}
          />
        </div>
      ))}
    </div>

    <!-- Estado vazio -->
    <div id="empty-state" class="hidden text-center py-20">
      <p class="text-muted text-lg">Nenhum artigo encontrado.</p>
      <button id="clear-filters" class="mt-4 text-brand underline underline-offset-2 text-sm">
        Limpar busca e filtros
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLElement>('.category-btn');
  const items = document.querySelectorAll<HTMLElement>('[data-category-item]');
  const emptyState = document.getElementById('empty-state')!;
  const searchInput = document.getElementById('post-search') as HTMLInputElement;
  const clearFiltersBtn = document.getElementById('clear-filters')!;

  let activeCategory = 'Todas';

  // Remove acentos para busca tolerante ("violao" encontra "violão")
  const COMBINING_DIACRITICS = /[̀-ͯ]/g;
  function normalizeSearch(text: string): string {
    return text.normalize('NFD').replace(COMBINING_DIACRITICS, '').toLowerCase();
  }

  function applyFilters() {
    const query = normalizeSearch(searchInput.value.trim());
    let visible = 0;

    items.forEach((item) => {
      const matchesCategory = activeCategory === 'Todas' || item.dataset.categoryItem === activeCategory;
      const matchesSearch = query === '' || (item.dataset.search ?? '').includes(query);
      const matches = matchesCategory && matchesSearch;
      item.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });

    emptyState.classList.toggle('hidden', visible > 0);

    buttons.forEach((btn) => {
      const active = btn.dataset.category === activeCategory;
      btn.classList.toggle('bg-brand', active);
      btn.classList.toggle('border-brand', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('text-muted', !active);
      btn.classList.toggle('border-border', !active);
      btn.setAttribute('aria-pressed', String(active));
    });

    const url = new URL(window.location.href);
    if (activeCategory === 'Todas') {
      url.searchParams.delete('categoria');
    } else {
      url.searchParams.set('categoria', activeCategory);
    }
    if (query === '') {
      url.searchParams.delete('q');
    } else {
      url.searchParams.set('q', query);
    }
    window.history.replaceState({}, '', url);
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category!;
      applyFilters();
    });
  });

  let debounceTimer: ReturnType<typeof setTimeout>;
  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(applyFilters, 150);
  });

  clearFiltersBtn.addEventListener('click', () => {
    activeCategory = 'Todas';
    searchInput.value = '';
    applyFilters();
  });

  // Aplica filtros vindos da URL ao carregar (categoria=, q=)
  const params = new URLSearchParams(window.location.search);
  const urlCategory = params.get('categoria');
  const urlQuery = params.get('q');
  if (urlCategory) activeCategory = urlCategory;
  if (urlQuery) searchInput.value = urlQuery;
  if (urlCategory || urlQuery) applyFilters();
</script>
