---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { generoAccent, generoGradient, generoSoft, iniciais } from '../../../utils/generos';

export async function getStaticPaths() {
  const bandas = await getCollection('bandas');
  return bandas.map((banda) => ({
    params: { slug: banda.id },
    props: { banda },
  }));
}

const { banda } = Astro.props;
const { nome, genero, origem, ano, blurb, fotoCapa, fotoCapaAlt, fotoCapaPosition, integrantes, albuns } = banda.data;

const accent = generoAccent(genero);
const gradient = generoGradient(genero);
const tagBg = generoSoft(genero);
const membersLabel = `${integrantes.length} ${integrantes.length === 1 ? 'integrante' : 'integrantes'}`;
const equipReady = integrantes.some((m) => m.setup.length > 0);

const albunsComLinks = albuns.map((album) => ({
  ...album,
  spotifyHref: album.spotifyUrl || `https://open.spotify.com/search/${encodeURIComponent(`${nome} ${album.nome}`)}`,
  saibaMaisHref: album.saibaMaisUrl || `https://pt.wikipedia.org/w/index.php?search=${encodeURIComponent(`${nome} ${album.nome} álbum`)}`,
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: nome,
  genre: genero,
  foundingDate: String(ano),
  ...(fotoCapa && { image: `https://sonarmusical.com.br${fotoCapa}` }),
  member: integrantes.map((m) => ({ '@type': 'Person', name: m.nome, roleName: m.funcao })),
};
---

<BaseLayout title={nome} description={blurb} image={fotoCapa} schema={schema}>
  <!-- Banner -->
  <div class="relative overflow-hidden border-b border-border" style={`background:${gradient};min-height:380px`}>
    {fotoCapa && (
      <img
        src={fotoCapa}
        alt={fotoCapaAlt ?? nome}
        class="absolute inset-0 w-full h-full object-cover"
        style={`object-position:center ${fotoCapaPosition ?? 20}%`}
        loading="eager"
        fetchpriority="high"
      />
    )}
    <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(10,10,10,.3),rgba(10,10,10,.82) 74%,#0a0a0a)"></div>
    <div class="relative max-w-6xl mx-auto px-4 pt-7 pb-10">
      <a
        href="/bandas"
        class="inline-flex items-center text-[13.5px] font-semibold text-white bg-black/40 border border-white/30 rounded-full px-4 py-2 backdrop-blur-sm hover:bg-black/55 transition-colors"
      >
        ← Todas as bandas
      </a>
      <div class="flex items-end gap-6 mt-32 flex-wrap">
        <div class="flex-1 min-w-64">
          <span
            class="inline-flex text-[11.5px] font-bold uppercase tracking-wider px-2.5 py-1.5 rounded-md"
            style={`background:${tagBg};color:${accent};border:1px solid rgba(255,255,255,.15)`}
          >
            {genero}
          </span>
          <h1 class="font-black tracking-tight leading-[0.95] mt-3" style="font-size:clamp(40px,7vw,76px)">{nome}</h1>
          <div class="text-base text-white/80 font-medium mt-2.5">{origem} · desde {ano} · {membersLabel}</div>
        </div>
      </div>
      <p class="max-w-2xl text-lg leading-relaxed text-white/90 mt-6">{blurb}</p>
    </div>
  </div>

  <!-- Integrantes -->
  <section class="max-w-6xl mx-auto px-4 pt-14 pb-5">
    <div class="flex items-center gap-3.5 mb-6.5">
      <span
        class="w-8.5 h-8.5 rounded-lg flex items-center justify-center font-extrabold text-base"
        style={`background:${tagBg};color:${accent}`}
      >
        01
      </span>
      <div>
        <h2 class="text-2xl font-extrabold tracking-tight">Integrantes</h2>
        <div class="text-sm text-muted">Quem forma a banda e o que cada um toca</div>
      </div>
    </div>
    <div class="grid gap-4" style="grid-template-columns:repeat(auto-fill,minmax(300px,1fr))">
      {integrantes.map((membro) => (
        <div class="bg-card border border-border rounded-2xl p-5 flex items-center gap-3.5">
          <div class="w-[54px] h-[54px] rounded-full flex-shrink-0 overflow-hidden flex items-center justify-center" style={`background:${gradient}`}>
            {membro.foto ? (
              <img src={membro.foto} alt={membro.fotoAlt ?? membro.nome} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <span class="text-sm font-extrabold text-white/90">{iniciais(membro.nome)}</span>
            )}
          </div>
          <div>
            <div class="text-[17px] font-bold tracking-tight">{membro.nome}</div>
            <div class="text-[13px] font-semibold" style={`color:${accent}`}>{membro.funcao}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Equipamentos CTA -->
  <section class="max-w-6xl mx-auto px-4 pt-11 pb-5">
    <div class="relative overflow-hidden rounded-[22px] border border-border p-8" style="background:linear-gradient(135deg,#141414,#0d0d0d)">
      <div class="flex items-start gap-4 flex-wrap">
        <span
          class="w-10 h-10 rounded-xl flex items-center justify-center font-extrabold text-[17px] flex-shrink-0"
          style={`background:${tagBg};color:${accent}`}
        >
          02
        </span>
        <div class="flex-1 min-w-60">
          <h2 class="text-2xl font-extrabold tracking-tight">Equipamentos ao vivo</h2>
          <p class="text-[15px] text-[#999] mt-1.5 max-w-xl leading-relaxed">
            Cada equipamento usado no palco por {nome} — com as versões budget-friendly pra chegar perto do som.
          </p>
          <div class="flex items-center gap-4 mt-5.5 flex-wrap">
            {equipReady ? (
              <a
                href={`/bandas/${banda.id}/equipamentos`}
                class="inline-flex items-center font-bold text-sm text-white bg-brand rounded-xl px-5.5 py-3.5 hover:bg-brand-dark transition-colors"
              >
                Ver equipamentos →
              </a>
            ) : (
              <span class="text-[13.5px] font-semibold" style={`color:${accent}`}>
                🚧 Página em construção — estamos montando o setup completo desta banda.
              </span>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Discografia -->
  {albuns.length > 0 && (
    <section class="pt-11 pb-24">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-center gap-3.5 mb-8">
          <span
            class="w-8.5 h-8.5 rounded-lg flex items-center justify-center font-extrabold text-base flex-shrink-0"
            style={`background:${tagBg};color:${accent}`}
          >
            03
          </span>
          <div>
            <h2 class="text-2xl font-extrabold tracking-tight">Discografia</h2>
            <div class="text-sm text-muted">Álbuns que marcaram a carreira de {nome}</div>
          </div>
        </div>
      </div>
      <div class="disco-shelf">
        <div class="disco-shelf__track max-w-6xl mx-auto px-4">
          {albunsComLinks.map((album) => (
            <div class="disco-card">
              <div class="disco-card__art">
                <div class="disco-card__vinyl" style={`background:${gradient}`}></div>
                <div class="disco-card__cover">
                  {album.capa ? (
                    <img src={album.capa} alt={album.capaAlt ?? album.nome} loading="lazy" />
                  ) : (
                    <div class="disco-card__cover-fallback" style={`background:${gradient}`}>
                      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="white" stroke-opacity="0.85" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18V5l12-2v13" />
                        <circle cx="6" cy="18" r="3" />
                        <circle cx="18" cy="16" r="3" />
                      </svg>
                    </div>
                  )}
                </div>
              </div>
              <div class="disco-card__nome">{album.nome}</div>
              {album.ano && <div class="disco-card__ano" style={`color:${accent}`}>{album.ano}</div>}
              <p class="disco-card__desc">{album.descricao}</p>
              <div class="disco-card__actions">
                <a
                  href={album.spotifyHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="disco-card__btn disco-card__btn--spotify"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.59 14.4a.622.622 0 0 1-.86.21c-2.35-1.44-5.31-1.76-8.79-.96a.624.624 0 1 1-.28-1.22c3.81-.87 7.08-.5 9.71 1.11.31.19.4.59.22.86zm1.22-2.72a.78.78 0 0 1-1.07.26c-2.69-1.65-6.79-2.13-9.98-1.17a.78.78 0 1 1-.45-1.49c3.64-1.1 8.16-.57 11.25 1.32.37.23.48.71.25 1.08zm.11-2.83c-3.23-1.92-8.56-2.09-11.64-1.16a.936.936 0 1 1-.54-1.79c3.54-1.07 9.41-.87 13.13 1.34a.936.936 0 0 1-.95 1.61z"/></svg>
                  Ouvir no Spotify
                </a>
                <a
                  href={album.saibaMaisHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="disco-card__btn disco-card__btn--info"
                >
                  Saiba mais →
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .disco-shelf {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
    scroll-snap-type: x proximity;
  }
  .disco-shelf__track {
    display: flex;
    gap: 34px;
    padding-bottom: 8px;
    padding-right: 34px;
  }
  .disco-card {
    flex: 0 0 190px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }
  .disco-card__art {
    position: relative;
    width: 190px;
    height: 190px;
    margin-bottom: 22px;
  }
  .disco-card__vinyl {
    position: absolute;
    right: -34px;
    bottom: -18px;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    opacity: 0.9;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .disco-card__vinyl::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: repeating-radial-gradient(circle, rgba(0, 0, 0, 0.55) 0px, rgba(0, 0, 0, 0.55) 1px, transparent 2px, transparent 5px);
  }
  .disco-card__vinyl::after {
    content: '';
    position: absolute;
    inset: 42%;
    border-radius: 50%;
    background: #0a0a0a;
    border: 3px solid rgba(255, 255, 255, 0.15);
  }
  .disco-card:hover .disco-card__vinyl {
    transform: translate(14px, -10px) rotate(35deg);
  }
  .disco-card__cover {
    position: relative;
    width: 190px;
    height: 190px;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .disco-card:hover .disco-card__cover {
    transform: translate(-6px, 4px) rotate(-2deg);
  }
  .disco-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .disco-card__cover-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .disco-card__nome {
    font-weight: 800;
    font-size: 15.5px;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .disco-card__ano {
    font-size: 12px;
    font-weight: 700;
    margin-top: 2px;
  }
  .disco-card__desc {
    font-size: 13px;
    color: #999;
    line-height: 1.5;
    margin-top: 6px;
    flex: 1;
  }
  .disco-card__actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 14px;
  }
  .disco-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 12.5px;
    font-weight: 700;
    border-radius: 9px;
    padding: 8px 12px;
    transition: filter 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }
  .disco-card__btn--spotify {
    background: #1db954;
    color: #04170b;
  }
  .disco-card__btn--spotify:hover {
    filter: brightness(1.08);
  }
  .disco-card__btn--info {
    background: transparent;
    color: #ccc;
    border: 1px solid #333;
  }
  .disco-card__btn--info:hover {
    border-color: #555;
    color: #fff;
  }
</style>
