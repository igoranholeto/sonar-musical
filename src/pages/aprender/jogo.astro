---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SKIN_COLORS } from '../../data/rpg';
---

<BaseLayout
  title="Rock Star Quest: Jogo de Guitarra Online Grátis"
  description="Rock Star Quest: crie seu personagem, escolha o visual e enfrente oponentes musicais respondendo perguntas de teoria musical em um RPG de pixel art."
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@600;700&display=swap" rel="stylesheet" />

  <section class="max-w-2xl mx-auto px-4 py-3 sm:py-12">
    <a href="/aprender/" class="inline-flex items-center gap-1.5 text-xs sm:text-sm text-muted hover:text-foreground transition-colors mb-2 sm:mb-6">
      ← Voltar para Aprender
    </a>

    <div id="rsq-root" class="max-w-md mx-auto">
      <!-- ============== CABEÇALHO DO JOGO (oculto na capa) ============== -->
      <div id="rsq-header" class="hidden text-center mb-2 sm:mb-5 relative">
        <button id="rsq-mute-btn" type="button" title="Ativar/desativar som" class="rsq-mute-btn" aria-label="Ativar/desativar som">
          <canvas id="rsq-mute-icon" width="26" height="20" style="width:26px;height:20px;"></canvas>
        </button>
        <div class="flex items-center justify-center gap-2.5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="sm:w-[26px] sm:h-[26px]" aria-hidden="true">
            <path d="M15.5 2.5L21 8L18.7 10.3L13.2 4.8L15.5 2.5Z" fill="#e63946"/>
            <rect x="12.2" y="5.8" width="2" height="8.4" transform="rotate(45 13.2 9.8)" fill="#e63946"/>
            <path d="M13 10.2C15.6 12.8 15.6 16.6 13 19.2C10.4 21.8 6.6 21.8 4 19.2C1.4 16.6 1.4 12.8 4 10.2C6.6 7.6 10.4 7.6 13 10.2Z" fill="#ffd23f"/>
            <circle cx="8.5" cy="14.7" r="3.4" fill="#1a0d22"/>
            <circle cx="8.5" cy="14.7" r="1.3" fill="#ffd23f"/>
          </svg>
          <span class="rsq-title-font text-lg sm:text-2xl font-black">Rock Star Quest</span>
        </div>
        <p class="hidden sm:block rsq-muted text-xs mt-1">Responda perguntas de teoria musical e derrote os inimigos do rock</p>
      </div>

      <!-- ============== TELA: CAPA ============== -->
      <div id="rsq-cover-screen" class="rsq-panel-dark rounded-[28px] relative overflow-hidden px-6 pt-6 sm:pt-12 pb-5 sm:pb-8 text-center">
        <button id="rsq-mute-btn-cover" type="button" title="Ativar/desativar som" class="rsq-mute-btn rsq-mute-btn--cover" aria-label="Ativar/desativar som">
          <canvas id="rsq-mute-icon-cover" width="26" height="20" style="width:26px;height:20px;"></canvas>
        </button>
        <div class="rsq-glow rsq-glow--red" aria-hidden="true"></div>
        <div class="rsq-glow rsq-glow--gold" aria-hidden="true"></div>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" class="relative mx-auto mb-2 sm:mb-4 sm:!w-16 sm:!h-16" aria-hidden="true">
          <path d="M15.5 2.5L21 8L18.7 10.3L13.2 4.8L15.5 2.5Z" fill="#e63946"/>
          <rect x="12.2" y="5.8" width="2" height="8.4" transform="rotate(45 13.2 9.8)" fill="#e63946"/>
          <path d="M13 10.2C15.6 12.8 15.6 16.6 13 19.2C10.4 21.8 6.6 21.8 4 19.2C1.4 16.6 1.4 12.8 4 10.2C6.6 7.6 10.4 7.6 13 10.2Z" fill="#ffd23f"/>
          <circle cx="8.5" cy="14.7" r="3.4" fill="#1a0d22"/>
          <circle cx="8.5" cy="14.7" r="1.3" fill="#ffd23f"/>
        </svg>
        <h1 class="relative rsq-title-font text-3xl sm:text-4xl font-black leading-tight">Rock Star<br />Quest</h1>
        <p class="relative rsq-text-soft text-xs sm:text-sm mt-2 sm:mt-3 max-w-[280px] mx-auto">
          Monte seu personagem, encare a plateia e responda perguntas de teoria musical para derrotar os inimigos do rock
        </p>
        <button id="rsq-play-btn" type="button" class="rsq-btn-primary relative mt-4 sm:mt-7 px-10 py-2.5 sm:py-3.5 rounded-2xl">▶ Jogar</button>
      </div>

      <!-- ============== TELA: CRIAÇÃO DE PERSONAGEM ============== -->
      <div id="rsq-creation-screen" class="hidden rsq-panel rounded-3xl p-3 sm:p-5">
        <div class="flex justify-center mb-2 sm:mb-4">
          <div class="rsq-panel-inset rounded-2xl p-1.5 sm:p-2.5">
            <canvas id="rsq-preview-canvas" width="160" height="170" style="image-rendering:pixelated;display:block;" class="w-[112px] h-[119px] sm:w-[160px] sm:h-[170px]"></canvas>
          </div>
        </div>

        <div class="mb-2.5 sm:mb-4">
          <label for="rsq-name-input" class="block text-xs sm:text-sm font-semibold mb-1 sm:mb-2">Nome do personagem</label>
          <input
            id="rsq-name-input"
            type="text"
            maxlength="16"
            placeholder="Ex: Sônica Sharp"
            class="rsq-input w-full px-3.5 py-2 sm:py-3 rounded-2xl text-sm focus:outline-none"
          />
        </div>

        <div class="mb-2.5 sm:mb-4">
          <div class="text-xs sm:text-sm font-semibold mb-1 sm:mb-2">Gênero</div>
          <div class="flex gap-2">
            <button type="button" data-gender="male" class="gender-swatch rsq-choice-btn flex items-center gap-1.5 px-4 py-1.5 sm:py-2.5 rounded-2xl text-sm font-semibold">
              <span class="text-base" aria-hidden="true">♂</span> Masculino
            </button>
            <button type="button" data-gender="female" class="gender-swatch rsq-choice-btn flex items-center gap-1.5 px-4 py-1.5 sm:py-2.5 rounded-2xl text-sm font-semibold">
              <span class="text-base" aria-hidden="true">♀</span> Feminino
            </button>
          </div>
        </div>

        <div class="mb-2.5 sm:mb-4">
          <div class="text-xs sm:text-sm font-semibold mb-1 sm:mb-2">Cor de pele</div>
          <div class="flex gap-2">
            {SKIN_COLORS.map((color) => (
              <button
                type="button"
                data-skin={color}
                class="skin-swatch w-[28px] h-[28px] sm:w-[34px] sm:h-[34px] rounded-full border-[3px] border-transparent transition-transform"
                style={`background:${color}`}
                aria-label={`Cor de pele ${color}`}
              />
            ))}
          </div>
        </div>

        <div class="mb-3 sm:mb-6">
          <div class="text-xs sm:text-sm font-semibold mb-1 sm:mb-2">Visual</div>
          <div id="rsq-look-grid" class="grid grid-cols-6 sm:grid-cols-3 gap-1 sm:gap-2"></div>
        </div>

        <button id="rsq-start-btn" class="rsq-btn-primary w-full py-2.5 sm:py-3.5 rounded-2xl">Começar Jornada</button>
        <p id="rsq-creation-error" class="hidden text-center text-xs mt-2.5" style="color:#ff6b6b;">Escolha um nome antes de começar.</p>
      </div>

      <!-- ============== TELA: ENCONTRO (VS) ============== -->
      <div id="rsq-walk-screen" class="hidden">
        <div class="rsq-vs-stage relative rounded-[20px] overflow-hidden" style="height:220px;">
          <div id="rsq-vs-player-card" class="rsq-vs-card rsq-vs-card--player">
            <canvas id="rsq-walk-player-canvas" width="96" height="120" style="width:96px;height:120px;image-rendering:pixelated;"></canvas>
          </div>
          <div id="rsq-vs-enemy-card" class="rsq-vs-card rsq-vs-card--enemy">
            <canvas id="rsq-walk-enemy-canvas" width="96" height="120" style="width:96px;height:120px;image-rendering:pixelated;"></canvas>
          </div>
          <div id="rsq-vs-label" class="rsq-vs-word">VS</div>
          <div id="rsq-walk-caption" class="rsq-vs-caption"></div>
        </div>
      </div>

      <!-- ============== TELA: BATALHA ============== -->
      <div id="rsq-battle-screen" class="hidden">
        <div class="flex items-center justify-between mb-1.5 sm:mb-2.5">
          <div id="rsq-hearts" class="flex gap-1"></div>
          <div id="rsq-round-label" class="rsq-title-font rsq-muted text-xs font-semibold"></div>
          <div id="rsq-score-label" class="rsq-title-font text-sm font-semibold" style="color:#ffd23f;"></div>
        </div>

        <div id="rsq-enemy-label" class="text-center text-sm font-bold mb-0.5 sm:mb-1"></div>
        <div id="rsq-enemy-hp" class="flex justify-center gap-1 mb-1.5 sm:mb-2.5"></div>

        <canvas id="rsq-battle-canvas" width="320" height="210" style="width:100%;image-rendering:pixelated;" class="rsq-battle-canvas rounded-[20px] mb-1.5 sm:mb-3.5 max-w-[240px] sm:max-w-none mx-auto block"></canvas>

        <div class="rsq-timer-track h-2 rounded-full overflow-hidden mb-2 sm:mb-4">
          <div id="rsq-timer-bar" class="h-full rounded-full transition-[width] duration-100 linear" style="width:100%;background:#e63946;"></div>
        </div>

        <h2 id="rsq-question" class="text-sm sm:text-[17px] font-bold leading-snug mb-2 sm:mb-3.5"></h2>

        <div id="rsq-hint-box" class="hidden mb-2 sm:mb-3.5 rsq-hint-box rounded-2xl p-2.5 flex gap-2.5 items-center">
          <canvas id="rsq-professor-canvas" width="56" height="56" style="width:44px;height:44px;flex-shrink:0;"></canvas>
          <div class="text-[13px] leading-snug"><strong class="rsq-title-font">Professor Sonar:</strong> <span id="rsq-hint-text"></span></div>
        </div>

        <div id="rsq-options" class="grid grid-cols-1 sm:grid-cols-2 gap-1.5 sm:gap-2.5 mb-2 sm:mb-4"></div>

        <div class="flex items-center justify-center gap-2 sm:gap-3">
          <button id="rsq-item-revive" class="rsq-item-btn flex flex-col items-center gap-0.5 sm:gap-1 px-2.5 sm:px-3.5 py-1.5 sm:py-2 rounded-2xl text-[10px] font-semibold" title="Vida extra: recupera 1 coração">
            <canvas class="rsq-item-icon" width="32" height="32" style="width:24px;height:24px;"></canvas>
            Vida extra
          </button>
          <button id="rsq-item-cut" class="rsq-item-btn flex flex-col items-center gap-0.5 sm:gap-1 px-2.5 sm:px-3.5 py-1.5 sm:py-2 rounded-2xl text-[10px] font-semibold" title="Remove 2 alternativas erradas">
            <canvas class="rsq-item-icon" width="32" height="32" style="width:24px;height:24px;"></canvas>
            Cortar 2
          </button>
          <button id="rsq-item-hint" class="rsq-item-btn flex flex-col items-center gap-0.5 sm:gap-1 px-2.5 sm:px-3.5 py-1.5 sm:py-2 rounded-2xl text-[10px] font-semibold" title="Ajuda do Professor Sonar">
            <canvas class="rsq-item-icon" width="32" height="32" style="width:24px;height:24px;"></canvas>
            Dica
          </button>
        </div>
      </div>

      <!-- ============== TELA: FIM DE JOGO ============== -->
      <div id="rsq-gameover-screen" class="hidden rsq-panel rounded-3xl overflow-hidden">
        <div class="rsq-gameover-hero relative px-6 pt-4 sm:pt-7 pb-3 sm:pb-5 text-center overflow-hidden">
          <canvas id="rsq-vinyl-canvas" width="200" height="200" style="display:block;margin:0 auto 8px auto;position:relative;" class="w-[76px] h-[76px] sm:w-[104px] sm:h-[104px] sm:!mb-3.5"></canvas>
          <div class="rsq-title-font relative text-[11px] font-semibold uppercase tracking-[1.5px] mb-1" style="color:#ff6b6b;">Fim da Turnê</div>
          <div id="rsq-final-score" class="rsq-title-font relative text-2xl sm:text-[38px] font-black leading-none" style="color:#ffd23f;"></div>
          <div class="relative rsq-muted text-[11px] uppercase tracking-wide mt-1">pontos na set list</div>
        </div>

        <div class="rsq-divider"></div>

        <div class="px-4 sm:px-6 py-3 sm:py-5">
          <div class="grid grid-cols-2 gap-2 mb-2.5 sm:mb-5">
            <div class="rsq-panel-inset rounded-2xl py-2 sm:py-3 px-1.5 text-center">
              <div id="rsq-final-bosses" class="rsq-title-font text-xl font-black" style="color:#ff6b6b;"></div>
              <div class="rsq-muted text-[10px] uppercase tracking-wide mt-0.5">Bosses</div>
            </div>
            <div class="rsq-panel-inset rounded-2xl py-2 sm:py-3 px-1.5 text-center">
              <div id="rsq-final-difficulty" class="rsq-title-font text-[13px] font-black mt-0.5"></div>
              <div class="rsq-muted text-[10px] uppercase tracking-wide mt-1">Nível alcançado</div>
            </div>
          </div>

          <div class="mb-2.5 sm:mb-5">
            <label for="rsq-name-submit-input" class="block rsq-muted text-[10px] uppercase tracking-wide mb-1 sm:mb-2">Entrar no ranking global</label>
            <div class="flex gap-2">
              <input
                id="rsq-name-submit-input"
                type="text"
                maxlength="16"
                placeholder="Seu nome"
                class="rsq-input flex-1 px-3 py-2 sm:py-2.5 rounded-xl text-[13px] focus:outline-none"
              />
              <button id="rsq-submit-score-btn" class="rsq-btn-primary px-4 py-2 sm:py-2.5 rounded-xl text-[13px] whitespace-nowrap">Enviar</button>
            </div>
            <p id="rsq-submit-status" class="rsq-muted text-[11px] mt-1 sm:mt-2"></p>
          </div>

          <div class="mb-2.5 sm:mb-5">
            <div class="rsq-muted text-[10px] uppercase tracking-wide mb-1 sm:mb-2">🏆 Ranking Global</div>
            <div class="rsq-panel-inset rounded-2xl p-1.5 flex flex-col gap-1 max-h-[140px] sm:max-h-none overflow-y-auto">
              <ol id="rsq-leaderboard-list" class="flex flex-col gap-1"></ol>
            </div>
          </div>

          <button id="rsq-play-again-btn" class="rsq-btn-primary w-full py-2.5 sm:py-3.5 rounded-2xl">Jogar de novo</button>
        </div>
      </div>
    </div>

    <p class="max-w-md mx-auto text-center text-[11px] text-subtle mt-3 sm:mt-6">
      Sprites de personagem: <a href="https://github.com/LiberatedPixelCup/Universal-LPC-Spritesheet-Character-Generator" target="_blank" rel="noopener noreferrer" class="underline hover:text-muted">Universal LPC Spritesheet Character Generator</a>, licenciado sob CC-BY-SA 3.0 / GPL 3.0.
    </p>
  </section>
</BaseLayout>

<style is:global>
  #rsq-root {
    --rsq-bg-1: #1a0d22;
    --rsq-bg-2: #3a1740;
    --rsq-panel: #1f1330;
    --rsq-panel-inset: #150b1f;
    --rsq-border: rgba(255, 255, 255, 0.08);
    --rsq-border-strong: rgba(255, 255, 255, 0.14);
    --rsq-text: #f5f0fa;
    --rsq-text-soft: #d9c9e8;
    --rsq-text-muted: #b9aecb;
    --rsq-gold: #ffd23f;
    --rsq-danger: #ff6b6b;
    --rsq-success: #3ddc84;
    color: var(--rsq-text);
  }

  .rsq-title-font {
    font-family: 'Fredoka', var(--font-sans), sans-serif;
  }

  .rsq-panel {
    background: var(--rsq-panel);
    border: 1px solid var(--rsq-border);
  }
  .rsq-panel-dark {
    background: linear-gradient(160deg, var(--rsq-bg-2), var(--rsq-bg-1) 70%);
    border: 1px solid var(--rsq-border);
  }
  .rsq-panel-inset {
    background: var(--rsq-panel-inset);
    border: 1px solid var(--rsq-border);
  }
  .rsq-muted {
    color: var(--rsq-text-muted);
  }
  .rsq-text-soft {
    color: var(--rsq-text-soft);
  }

  .rsq-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .rsq-glow--red {
    top: -40px;
    left: -40px;
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, rgba(230, 57, 70, 0.35), transparent 70%);
  }
  .rsq-glow--gold {
    bottom: -60px;
    right: -50px;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(255, 210, 63, 0.22), transparent 70%);
  }

  .rsq-mute-btn {
    position: absolute;
    top: 0;
    right: 0;
    width: 36px;
    height: 36px;
    border-radius: 12px;
    border: 1px solid var(--rsq-border-strong);
    background: var(--rsq-panel);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .rsq-mute-btn--cover {
    top: 14px;
    right: 14px;
    background: rgba(21, 11, 31, 0.6);
  }

  .rsq-btn-primary {
    background: #e63946;
    color: white;
    font-weight: 700;
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 22px rgba(230, 57, 70, 0.35);
    transition: background-color 0.15s ease;
  }
  .rsq-btn-primary:hover {
    background: #b5202d;
  }
  .rsq-btn-primary:disabled {
    opacity: 0.5;
    cursor: default;
    box-shadow: none;
  }

  .rsq-input {
    background: var(--rsq-panel-inset);
    border: 1px solid var(--rsq-border-strong);
    color: var(--rsq-text);
  }
  .rsq-input::placeholder {
    color: var(--rsq-text-muted);
    opacity: 0.7;
  }
  .rsq-input:focus {
    border-color: #e63946;
  }

  .rsq-choice-btn {
    border: 2px solid var(--rsq-border-strong);
    background: var(--rsq-panel);
    color: var(--rsq-text);
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .rsq-choice-btn.is-active {
    border-color: #e63946;
    background: rgba(230, 57, 70, 0.12);
  }

  #rsq-root .skin-swatch {
    cursor: pointer;
    transition: transform 0.15s ease;
  }
  #rsq-root .skin-swatch.is-active {
    border-color: var(--rsq-gold) !important;
    transform: scale(1.12);
  }

  #rsq-root .look-swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 4px 2px 5px;
    border-radius: 14px;
    border: 2px solid var(--rsq-border-strong);
    background: var(--rsq-panel);
    color: var(--rsq-text);
    font-size: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  #rsq-root .look-swatch.is-active {
    border-color: var(--rsq-gold);
    background: rgba(255, 210, 63, 0.1);
  }

  .rsq-vs-stage {
    border: 1px solid var(--rsq-border);
    background: radial-gradient(ellipse at 50% 40%, var(--rsq-bg-2) 0%, var(--rsq-bg-1) 75%);
  }
  .rsq-vs-card {
    position: absolute;
    top: 16px;
    width: 96px;
    height: 120px;
    background: var(--rsq-panel-inset);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.2, 0.8, 0.3, 1.3), opacity 0.3s;
  }
  .rsq-vs-card--player {
    left: 16px;
    border: 2px solid var(--rsq-gold);
    transform: translateX(-140px) rotate(-8deg);
  }
  .rsq-vs-card--enemy {
    right: 16px;
    border: 2px solid #e63946;
    transform: translateX(140px) rotate(8deg);
  }
  .rsq-vs-card.is-in {
    transform: translateX(0) rotate(0deg);
    opacity: 1;
  }
  .rsq-vs-word {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.2);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s;
    font-family: 'Fredoka', var(--font-sans), sans-serif;
    font-weight: 700;
    font-size: 34px;
    color: var(--rsq-gold);
    text-shadow: 0 0 14px rgba(255, 210, 63, 0.7), 2px 2px 0 var(--rsq-bg-1);
  }
  .rsq-vs-word.is-in {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
  .rsq-vs-caption {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .rsq-vs-caption.is-in {
    opacity: 1;
  }

  .rsq-battle-canvas {
    border: 1px solid var(--rsq-border);
    display: block;
  }
  .rsq-timer-track {
    background: var(--rsq-panel);
  }

  .rsq-hint-box {
    background: rgba(230, 57, 70, 0.1);
    border: 1px solid rgba(230, 57, 70, 0.3);
  }

  .rsq-option-btn {
    text-align: left;
    padding: 13px 14px;
    border-radius: 14px;
    font-size: 13.5px;
    font-weight: 500;
    cursor: pointer;
    color: var(--rsq-text);
    border: 2px solid var(--rsq-border-strong);
    background: var(--rsq-panel);
    transition: border-color 0.15s ease, background-color 0.15s ease, opacity 0.15s ease;
  }
  @media (max-width: 639px) {
    .rsq-option-btn {
      padding: 8px 10px;
      font-size: 12.5px;
      border-radius: 12px;
    }
  }
  .rsq-option-btn.is-correct {
    background: rgba(61, 220, 132, 0.12);
    border-color: var(--rsq-success);
  }
  .rsq-option-btn.is-wrong {
    background: rgba(255, 107, 107, 0.12);
    border-color: var(--rsq-danger);
  }
  .rsq-option-btn.is-faded {
    opacity: 0.4;
  }
  .rsq-option-btn.is-cut {
    opacity: 0.3;
    text-decoration: line-through;
  }

  .rsq-item-btn {
    border: 1px solid var(--rsq-border-strong);
    background: var(--rsq-panel);
    color: var(--rsq-text-muted);
    cursor: default;
    opacity: 0.35;
