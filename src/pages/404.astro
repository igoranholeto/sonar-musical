---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página não encontrada"
  description="A página que você está procurando não existe no Sonar Musical."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
    <p class="text-8xl font-black text-brand/20 mb-4" aria-hidden="true">404</p>
    <h1 class="text-3xl font-bold mb-4">Página não encontrada</h1>
    <p class="text-muted max-w-sm mb-8">
      Esta página não existe ou foi movida. Que tal navegar pelas nossas análises?
    </p>
    <div class="flex gap-4">
      <a
        href="/"
        class="px-6 py-3 bg-brand text-white font-semibold rounded-xl hover:bg-brand-dark transition-colors"
      >
        Ir para o Início
      </a>
      <a
        href="/blog"
        class="px-6 py-3 bg-foreground/5 border border-border text-foreground font-semibold rounded-xl hover:bg-foreground/10 transition-colors"
      >
        Ver Análises
      </a>
    </div>
  </div>
</BaseLayout>
