---
import { slugifyCategory } from '../utils/slug';

const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/bandas', label: 'Bandas' },
  { href: '/tablaturas', label: 'Tablaturas' },
  { href: '/aprender', label: 'Aprender' },
  { href: '/afinador', label: 'Afinador' },
  { href: '/about', label: 'Sobre' },
  { href: '/contact', label: 'Contato' },
];

// Subcategorias com maior potencial de SEO (volume de busca real, via keyword research)
const analiseCategorias = [
  'Guitarras',
  'Amplificadores',
  'Pedais',
  'Acessórios',
  'Violões',
  'Guias de Compra',
  'Técnica e Teoria',
];

const currentPath = Astro.url.pathname;
const isAnalisesActive = currentPath.startsWith('/blog') || currentPath.startsWith('/categoria');
---

<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegação principal">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl group" aria-label="Sonar Musical — página inicial">
      <span class="flex items-center justify-center w-8 h-8 bg-brand rounded-lg text-white" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M9 18V5l12-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="18" cy="16" r="3" />
        </svg>
      </span>
      <span class="group-hover:text-brand transition-colors">
        Sonar<span class="text-brand">Musical</span>
      </span>
    </a>

    <!-- Nav desktop -->
    <ul class="hidden lg:flex items-center gap-0.5" role="list">
      <li>
        <a
          href="/"
          aria-current={currentPath === '/' ? 'page' : undefined}
          class={`px-3 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors ${
            currentPath === '/'
              ? 'text-brand bg-brand/10'
              : 'text-muted hover:text-foreground hover:bg-foreground/5'
          }`}
        >
          Início
        </a>
      </li>

      <!-- Análises com dropdown de subcategorias -->
      <li class="relative" id="analises-menu-item">
        <div
          class={`flex items-center rounded-lg transition-colors ${
            isAnalisesActive ? 'text-brand bg-brand/10' : 'text-muted hover:text-foreground hover:bg-foreground/5'
          }`}
        >
          <a
            href="/blog"
            aria-current={isAnalisesActive ? 'page' : undefined}
            class="pl-3 pr-1.5 py-2 text-sm font-medium whitespace-nowrap"
          >
            Análises
          </a>
          <button
            id="analises-dropdown-btn"
            type="button"
            aria-expanded="false"
            aria-controls="analises-dropdown"
            aria-label="Ver categorias de análises"
            class="pr-2.5 py-2"
          >
            <svg id="analises-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
        </div>

        <div
          id="analises-dropdown"
          class="hidden absolute left-0 top-full mt-1 w-56 rounded-xl border border-border bg-card shadow-lg py-2 z-50"
          role="menu"
        >
          {analiseCategorias.map((cat) => (
            <a
              href={`/categoria/${slugifyCategory(cat)}/`}
              role="menuitem"
              class="block px-4 py-2 text-sm text-muted hover:text-foreground hover:bg-foreground/5 transition-colors"
            >
              {cat}
            </a>
          ))}
          <div class="my-1.5 border-t border-border"></div>
          <a
            href="/blog"
            role="menuitem"
            class="block px-4 py-2 text-sm font-semibold text-brand hover:bg-foreground/5 transition-colors"
          >
            Ver todas as análises →
          </a>
        </div>
      </li>

      {navLinks.filter(({ href }) => href !== '/').map(({ href, label }) => {
        const isActive = currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={`px-3 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors ${
                isActive
                  ? 'text-brand bg-brand/10'
                  : 'text-muted hover:text-foreground hover:bg-foreground/5'
              }`}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="flex items-center gap-2">
      <!-- Toggle de tema claro/escuro -->
      <button
        id="theme-toggle"
        type="button"
        role="switch"
        aria-checked="true"
        aria-label="Alternar entre tema claro e escuro"
        class="relative inline-flex h-8 w-14 flex-shrink-0 items-center rounded-full border border-border bg-elevated transition-colors"
      >
        <span
          id="theme-toggle-thumb"
          class="flex h-6 w-6 translate-x-1 items-center justify-center rounded-full bg-card shadow-md transition-transform duration-300 dark:translate-x-7"
        >
          <svg id="icon-sun" class="block dark:hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f5b700" stroke-width="2.5" stroke-linecap="round">
            <circle cx="12" cy="12" r="4" />
            <line x1="12" y1="2" x2="12" y2="4.5" />
            <line x1="12" y1="19.5" x2="12" y2="22" />
            <line x1="4.2" y1="4.2" x2="6" y2="6" />
            <line x1="18" y1="18" x2="19.8" y2="19.8" />
            <line x1="2" y1="12" x2="4.5" y2="12" />
            <line x1="19.5" y1="12" x2="22" y2="12" />
            <line x1="4.2" y1="19.8" x2="6" y2="18" />
            <line x1="18" y1="6" x2="19.8" y2="4.2" />
          </svg>
          <svg id="icon-moon" class="hidden dark:block" width="14" height="14" viewBox="0 0 24 24" fill="#64748b" stroke="none">
            <path d="M20.5 14.5a8.5 8.5 0 1 1-9-13 7 7 0 0 0 9 9c0 1.4 0 3.3 0 4z" />
          </svg>
        </span>
      </button>

      <!-- Botão menu mobile -->
      <button
        id="mobile-menu-btn"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="lg:hidden p-2 rounded-lg text-muted hover:text-foreground hover:bg-foreground/5 transition-colors"
        aria-label="Abrir menu"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-border"
    role="dialog"
    aria-label="Navegação mobile"
  >
    <ul class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1" role="list">
      <li>
        <a
          href="/"
          aria-current={currentPath === '/' ? 'page' : undefined}
          class={`block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
            currentPath === '/' ? 'text-brand bg-brand/10' : 'text-muted hover:text-foreground hover:bg-foreground/5'
          }`}
        >
          Início
        </a>
      </li>

      <li>
        <div
          class={`flex items-center rounded-lg transition-colors ${
            isAnalisesActive ? 'text-brand bg-brand/10' : 'text-muted hover:text-foreground hover:bg-foreground/5'
          }`}
        >
          <a
            href="/blog"
            aria-current={isAnalisesActive ? 'page' : undefined}
            class="flex-1 block pl-4 pr-2 py-2.5 text-sm font-medium"
          >
            Análises
          </a>
          <button
            id="mobile-analises-btn"
            type="button"
            aria-expanded="false"
            aria-controls="mobile-analises-submenu"
            aria-label="Ver categorias de análises"
            class="pr-3 py-2.5"
          >
            <svg id="mobile-analises-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
        </div>
        <ul id="mobile-analises-submenu" class="hidden mt-1 ml-3 flex flex-col gap-0.5 border-l border-border pl-3" role="list">
          {analiseCategorias.map((cat) => (
            <li>
              <a
                href={`/categoria/${slugifyCategory(cat)}/`}
                class="block px-3 py-1.5 rounded-lg text-sm text-muted hover:text-foreground hover:bg-foreground/5 transition-colors"
              >
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </li>

      {navLinks.filter(({ href }) => href !== '/').map(({ href, label }) => {
        const isActive = currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={`block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                isActive
                  ? 'text-brand bg-brand/10'
                  : 'text-muted hover:text-foreground hover:bg-foreground/5'
              }`}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    iconMenu.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });

  const themeToggle = document.getElementById('theme-toggle')!;
  const themeColorMeta = document.querySelector('meta[name="theme-color"]');

  themeToggle.setAttribute('aria-checked', String(document.documentElement.classList.contains('dark')));

  themeToggle.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    themeToggle.setAttribute('aria-checked', String(isDark));
    themeColorMeta?.setAttribute('content', isDark ? '#0a0a0a' : '#ffffff');
  });

  // Dropdown de categorias "Análises"
  const dropdownBtn = document.getElementById('analises-dropdown-btn')!;
  const dropdown = document.getElementById('analises-dropdown')!;
  const dropdownIcon = document.getElementById('analises-dropdown-icon')!;
  const analisesMenuItem = document.getElementById('analises-menu-item')!;
  let dropdownCloseTimer: ReturnType<typeof setTimeout> | null = null;

  function openDropdown() {
    if (dropdownCloseTimer) {
      clearTimeout(dropdownCloseTimer);
      dropdownCloseTimer = null;
    }
    dropdown.classList.remove('hidden');
    dropdownBtn.setAttribute('aria-expanded', 'true');
    dropdownIcon.classList.add('rotate-180');
  }

  function closeDropdown() {
    dropdown.classList.add('hidden');
    dropdownBtn.setAttribute('aria-expanded', 'false');
    dropdownIcon.classList.remove('rotate-180');
  }

  function toggleDropdown() {
    if (dropdown.classList.contains('hidden')) openDropdown();
    else closeDropdown();
  }

  dropdownBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleDropdown();
  });

  // Abre ao passar o mouse (desktop); o delay no fechamento evita
  // que o menu suma ao mover o cursor do botão até a lista.
  const hoverCapable = window.matchMedia('(hover: hover)').matches;
  if (hoverCapable) {
    analisesMenuItem.addEventListener('mouseenter', openDropdown);
    analisesMenuItem.addEventListener('mouseleave', () => {
      dropdownCloseTimer = setTimeout(closeDropdown, 150);
    });
  }

  document.addEventListener('click', (e) => {
    if (!dropdown.contains(e.target as Node) && e.target !== dropdownBtn) closeDropdown();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });

  // Accordion de categorias "Análises" no menu mobile
  const mobileAnalisesBtn = document.getElementById('mobile-analises-btn')!;
  const mobileAnalisesSubmenu = document.getElementById('mobile-analises-submenu')!;
  const mobileAnalisesIcon = document.getElementById('mobile-analises-icon')!;

  mobileAnalisesBtn.addEventListener('click', () => {
    const isOpen = mobileAnalisesSubmenu.classList.toggle('hidden') === false;
    mobileAnalisesBtn.setAttribute('aria-expanded', String(isOpen));
    mobileAnalisesIcon.classList.toggle('rotate-180', isOpen);
  });
</script>
