---
const navLinks = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Análises' },
  { href: '/about', label: 'Sobre' },
  { href: '/contact', label: 'Contato' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegação principal">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl group" aria-label="Sonar Musical — página inicial">
      <span class="flex items-center justify-center w-8 h-8 bg-brand rounded-lg text-white" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M9 18V5l12-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="18" cy="16" r="3" />
        </svg>
      </span>
      <span class="group-hover:text-brand transition-colors">
        Sonar<span class="text-brand">Musical</span>
      </span>
    </a>

    <!-- Nav desktop -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                isActive
                  ? 'text-brand bg-brand/10'
                  : 'text-gray-400 hover:text-white hover:bg-white/5'
              }`}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Botão menu mobile -->
    <button
      id="mobile-menu-btn"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="md:hidden p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-colors"
      aria-label="Abrir menu"
    >
      <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border"
    role="dialog"
    aria-label="Navegação mobile"
  >
    <ul class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class={`block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                isActive
                  ? 'text-brand bg-brand/10'
                  : 'text-gray-400 hover:text-white hover:bg-white/5'
              }`}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    iconMenu.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });
</script>
