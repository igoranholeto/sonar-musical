---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer.replace(/<[^>]+>/g, ''),
    },
  })),
};
---

<section class="mt-12 pt-10 border-t border-border" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="text-xl font-bold mb-6">Perguntas frequentes</h2>
  <div class="space-y-3">
    {items.map((item, i) => (
      <details class="group bg-card border border-border rounded-xl overflow-hidden" open={i === 0}>
        <summary class="cursor-pointer list-none flex items-center justify-between gap-4 px-5 py-4 font-semibold text-sm marker:content-none">
          <span>{item.question}</span>
          <svg
            class="shrink-0 transition-transform duration-200 group-open:rotate-180"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <div class="faq-answer px-5 pb-4 text-sm text-muted leading-relaxed" set:html={item.answer} />
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  summary::-webkit-details-marker {
    display: none;
  }
  .faq-answer :global(a) {
    color: #e63946;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .faq-answer :global(a:hover) {
    color: #ff5b67;
  }
</style>
