---
const categories = [
  {
    name: 'Guitarras',
    description: 'Elétricas e acústicas',
    icon: '🎸',
    color: 'from-blue-50 to-blue-50/50 border-blue-200 hover:border-blue-400 dark:from-blue-900/30 dark:to-blue-900/10 dark:border-blue-800/30 dark:hover:border-blue-600/50',
    badge: 'text-blue-700 dark:text-blue-300',
  },
  {
    name: 'Amplificadores',
    description: 'Combos, heads e gabinetes',
    icon: '🔊',
    color: 'from-amber-50 to-amber-50/50 border-amber-200 hover:border-amber-400 dark:from-amber-900/30 dark:to-amber-900/10 dark:border-amber-800/30 dark:hover:border-amber-600/50',
    badge: 'text-amber-700 dark:text-amber-300',
  },
  {
    name: 'Pedais',
    description: 'Efeitos e chain de sinal',
    icon: '⚡',
    color: 'from-green-50 to-green-50/50 border-green-200 hover:border-green-400 dark:from-green-900/30 dark:to-green-900/10 dark:border-green-800/30 dark:hover:border-green-600/50',
    badge: 'text-green-700 dark:text-green-300',
  },
  {
    name: 'Acessórios',
    description: 'Cordas, palhetas, cabos',
    icon: '🎵',
    color: 'from-purple-50 to-purple-50/50 border-purple-200 hover:border-purple-400 dark:from-purple-900/30 dark:to-purple-900/10 dark:border-purple-800/30 dark:hover:border-purple-600/50',
    badge: 'text-purple-700 dark:text-purple-300',
  },
  {
    name: 'Guias de Compra',
    description: 'Recomendações curadas',
    icon: '📋',
    color: 'from-brand/20 to-brand/5 border-brand/20 hover:border-brand/50',
    badge: 'text-brand',
  },
  {
    name: 'Dicas para Iniciantes',
    description: 'Comece sua jornada bem',
    icon: '🎓',
    color: 'from-teal-50 to-teal-50/50 border-teal-200 hover:border-teal-400 dark:from-teal-900/30 dark:to-teal-900/10 dark:border-teal-800/30 dark:hover:border-teal-600/50',
    badge: 'text-teal-700 dark:text-teal-300',
  },
];
---

<section class="py-16 max-w-6xl mx-auto px-4">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold">Explorar por Categoria</h2>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
    {categories.map(({ name, description, icon, color, badge }) => (
      <a
        href={`/blog?categoria=${encodeURIComponent(name)}`}
        class={`group flex flex-col items-center text-center p-5 rounded-xl border bg-gradient-to-b transition-all duration-300 ${color}`}
      >
        <span class="text-3xl mb-3" aria-hidden="true">{icon}</span>
        <span class={`text-sm font-semibold ${badge} mb-1`}>{name}</span>
        <span class="text-xs text-subtle leading-tight hidden sm:block">{description}</span>
      </a>
    ))}
  </div>
</section>
