---
import { getCollection } from 'astro:content';
import { slugifyCategory } from '../utils/slug';

const allPosts = await getCollection('blog');
const countByCategory = new Map<string, number>();
for (const post of allPosts) {
  countByCategory.set(post.data.category, (countByCategory.get(post.data.category) ?? 0) + 1);
}

const categories = [
  {
    name: 'Guitarras',
    description: 'Elétricas e acústicas',
    icon: '<path d="M12 2C8 2 4 6 4 11c0 5 4 9 8 11 4-2 8-6 8-11 0-5-4-9-8-9z"/>',
  },
  {
    name: 'Amplificadores',
    description: 'Combos, heads e gabinetes',
    icon: '<rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="12" cy="9" r="3"/><circle cx="12" cy="16" r="1.4"/>',
  },
  {
    name: 'Pedais',
    description: 'Efeitos e chain de sinal',
    icon: '<rect x="4" y="9" width="16" height="9" rx="2"/><circle cx="12" cy="13.5" r="2"/><path d="M8 9V6h8v3"/>',
  },
  {
    name: 'Acessórios',
    description: 'Cordas, palhetas, cabos',
    icon: '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.8 2.8-2-2 2.8-2.8z"/>',
  },
  {
    name: 'Guias de Compra',
    description: 'Recomendações curadas',
    icon: '<rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 9.5l1.5 1.5L13 7.5"/><path d="M8 14.5h8"/><path d="M8 17.5h5"/>',
  },
  {
    name: 'Dicas para Iniciantes',
    description: 'Comece sua jornada bem',
    icon: '<path d="M12 3a6 6 0 0 0-4 10.5c.6.5 1 1.3 1 2.5h6c0-1.2.4-2 1-2.5A6 6 0 0 0 12 3z"/><path d="M9.5 18.5h5"/><path d="M10.5 21h3"/>',
  },
  {
    name: 'Violões',
    description: 'Acústicos e eletroacústicos',
    icon: '<circle cx="9.5" cy="15.5" r="5"/><circle cx="9.5" cy="15.5" r="2"/><path d="M11.5 11.7L18 3"/><path d="M15.7 5l2.6-1"/>',
  },
  {
    name: 'Home Studio',
    description: 'Interfaces, mics e monitores',
    icon: '<path d="M12 2a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><path d="M12 18v4"/><path d="M9 22h6"/>',
  },
  {
    name: 'Técnica e Teoria',
    description: 'Aprofunde seu conhecimento',
    icon: '<path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H12v18H6.5A2.5 2.5 0 0 1 4 18.5v-13z"/><path d="M20 5.5A2.5 2.5 0 0 0 17.5 3H12v18h5.5a2.5 2.5 0 0 0 2.5-2.5v-13z"/>',
  },
  {
    name: 'Tutoriais',
    description: 'Passo a passo prático',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M10 8.3l6 3.7-6 3.7V8.3z"/>',
  },
];
---

<section class="py-16 max-w-6xl mx-auto px-4">
  <div class="flex items-end justify-between mb-8">
    <div>
      <h2 class="text-2xl font-bold">Explorar por Categoria</h2>
      <p class="text-sm text-muted mt-1">Navegue pelo que já testamos e comparamos.</p>
    </div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
    {categories.map(({ name, description, icon }) => (
      <a
        href={`/categoria/${slugifyCategory(name)}/`}
        class="group relative flex flex-col p-5 rounded-xl border border-border bg-card hover:border-brand/50 hover:-translate-y-0.5 transition-all duration-200"
      >
        <span
          class="flex items-center justify-center w-10 h-10 rounded-lg bg-brand/10 text-brand mb-4 group-hover:bg-brand group-hover:text-white transition-colors duration-200"
          aria-hidden="true"
        >
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
        </span>
        <span class="text-sm font-semibold text-foreground mb-1">{name}</span>
        <span class="text-xs text-subtle leading-tight mb-3">{description}</span>
        <span class="mt-auto text-[0.7rem] font-medium text-muted">
          {countByCategory.get(name) ?? 0} {countByCategory.get(name) === 1 ? 'análise' : 'análises'}
        </span>
      </a>
    ))}
  </div>
</section>
