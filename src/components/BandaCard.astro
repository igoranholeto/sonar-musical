---
import { generoAccent, generoGradient, generoSoft } from '../utils/generos';

interface Props {
  nome: string;
  slug: string;
  genero: string;
  origem: string;
  ano: number;
  fotoCapa?: string;
  fotoCapaAlt?: string;
  integrantesCount: number;
}

const { nome, slug, genero, origem, ano, fotoCapa, fotoCapaAlt, integrantesCount } = Astro.props;

const accent = generoAccent(genero);
const gradient = generoGradient(genero);
const tagBg = generoSoft(genero);
const membersLabel = `${integrantesCount} ${integrantesCount === 1 ? 'integrante' : 'integrantes'}`;
---

<article
  data-band-card
  data-genre={genero}
  data-name={nome.toLowerCase()}
  data-year={ano}
  class="group bg-card border border-border rounded-2xl overflow-hidden transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-black/40"
  style={`--band-accent:${accent}`}
>
  <a href={`/bandas/${slug}`} class="block" aria-label={`Ver banda ${nome}`}>
    <div class="relative h-40 overflow-hidden" style={`background:${gradient}`}>
      {fotoCapa && (
        <img
          src={fotoCapa}
          alt={fotoCapaAlt ?? nome}
          width="400"
          height="160"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover"
        />
      )}
    </div>
    <div class="p-4">
      <span
        class="inline-flex items-center text-[11px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md"
        style={`background:${tagBg};color:${accent}`}
      >
        {genero}
      </span>
      <h3 class="text-lg font-extrabold tracking-tight mt-3">{nome}</h3>
      <div class="text-sm text-muted mt-1">{origem} · {ano}</div>
      <div class="flex items-center justify-between mt-4 pt-3.5 border-t border-border">
        <span class="text-xs text-muted font-medium">{membersLabel}</span>
        <span class="text-xs font-bold band-card-cta" style={`color:${accent}`}>ver banda →</span>
      </div>
    </div>
  </a>
</article>

<style>
  [data-band-card] {
    border-color: #242424;
  }
  [data-band-card]:hover {
    border-color: var(--band-accent);
  }
</style>
