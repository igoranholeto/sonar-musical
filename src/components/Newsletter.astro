---
---

<section class="py-16 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <div class="bg-elevated border border-border rounded-2xl p-10">
      <div class="inline-flex items-center justify-center w-14 h-14 bg-brand/10 rounded-xl mb-6" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
          <polyline points="22,6 12,13 2,6" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold mb-3">Fique por Dentro</h2>
      <p class="text-muted mb-8">
        Receba novas análises e guias de compra direto no seu e-mail — sem spam, só equipamento.
      </p>
      <form
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
        aria-label="Inscrição na newsletter"
        action="#"
        method="post"
        novalidate
      >
        <label for="email-input" class="sr-only">Endereço de e-mail</label>
        <input
          id="email-input"
          type="email"
          name="email"
          placeholder="seu@email.com"
          autocomplete="email"
          required
          class="flex-1 px-4 py-3 rounded-xl bg-card border border-border text-white placeholder-subtle text-sm focus:outline-none focus:border-brand transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-brand text-white font-semibold rounded-xl hover:bg-brand-dark transition-colors whitespace-nowrap shadow-lg shadow-brand/20"
        >
          Inscrever-se
        </button>
      </form>
      <p class="text-xs text-subtle mt-4">Cancele quando quiser. Sem spam, nunca.</p>
    </div>
  </div>
</section>
