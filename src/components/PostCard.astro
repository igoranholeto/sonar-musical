---
import Rating from './Rating.astro';
import { slugifyCategory } from '../utils/slug';
import { unsplashSrc } from '../utils/image';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: string;
  image?: string;
  imageAlt?: string;
  rating?: number;
  featured?: boolean;
  eager?: boolean;
}

const { title, description, slug, pubDate, category, image, imageAlt, rating, featured, eager = false } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const categoryColors: Record<string, string> = {
  Guitarras: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
  Amplificadores: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
  Pedais: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
  Acessórios: 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300',
  'Guias de Compra': 'bg-brand/20 text-brand',
  'Dicas para Iniciantes': 'bg-teal-100 text-teal-700 dark:bg-teal-900/40 dark:text-teal-300',
};
const badgeClass = categoryColors[category] ?? 'bg-elevated text-muted';
---

<article class="group bg-card rounded-xl border border-border overflow-hidden hover:border-brand/40 transition-all duration-300 flex flex-col">
  <!-- Imagem de capa -->
  <a href={`/blog/${slug}`} class="block overflow-hidden aspect-video bg-elevated relative" tabindex="-1" aria-hidden="true">
    {image ? (
      <img
        src={unsplashSrc(image, 400)}
        srcset={`${unsplashSrc(image, 400)} 1x, ${unsplashSrc(image, 800)} 2x`}
        alt={imageAlt ?? title}
        width="400"
        height="225"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        decoding={eager ? 'sync' : 'async'}
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-border)" stroke-width="1.5">
          <path d="M9 18V5l12-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="18" cy="16" r="3" />
        </svg>
      </div>
    )}
    {featured && (
      <span class="absolute top-3 left-3 text-xs font-bold uppercase tracking-wider bg-brand text-white px-2.5 py-1 rounded-full">
        Destaque
      </span>
    )}
  </a>

  <!-- Conteúdo -->
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3">
      <a
        href={`/categoria/${slugifyCategory(category)}/`}
        class={`text-xs font-semibold uppercase tracking-wider px-2.5 py-0.5 rounded-full ${badgeClass}`}
      >
        {category}
      </a>
      {rating && <Rating value={rating} size="sm" />}
    </div>

    <h2 class="text-base font-bold leading-snug mb-2 line-clamp-2">
      <a href={`/blog/${slug}`} class="hover:text-brand transition-colors">
        {title}
      </a>
    </h2>

    <p class="text-sm text-muted line-clamp-3 flex-1 mb-4">{description}</p>

    <div class="flex items-center justify-between text-xs text-subtle mt-auto">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <a
        href={`/blog/${slug}`}
        class="font-semibold text-brand hover:underline underline-offset-2"
        aria-label={`Ler: ${title}`}
      >
        Ler mais →
      </a>
    </div>
  </div>
</article>
